learning_objective_tree:
  title: 19. Classical and Quantum Cryptography
  global_prerequisites: []
  objectives:
  - lo_id: LO-19-01
    summary: Students will learn the relationship between classical cryptography and
      quantum cryptography
    covered_by:
    - m19-19-1-191SecretKeyCryp
    - m19-2-Untitled
    - m19-19-3-1932QuantumCrypt
    learning_objectives:
    - Apply knowledge of the mathematical basis for modern cryptosystems
    - Apply the concept of superposition to describe quantum cryptographic protocols.
    - Understand the definition of perfect secrecy
    - Understand how quantum cryptography uses physical laws for security instead
      of mathematical problems.
    - Understand the differences between secret key and classical cryptography
    - Analyze the limitations of AES, 3DES, Serpent, and Blowfish
    - Analyze the importance of key security in secret key cryptography
    - Analyze the role of entanglement in ensuring security in quantum key distribution.
    - Apply the concept of one-time pad to secure communication
    estimated_time_mins: 0
    concepts:
    - permutations
    - Entanglement
    - Non-orthogonal qubit states
    - substitution
