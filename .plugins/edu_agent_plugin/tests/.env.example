# =============================================================================
# Agent Evaluation LLM Configuration
# =============================================================================
# Copy this file to .env and configure your preferred LLM provider.
# The evaluation framework uses this LLM for RAGAS metrics (LLM-as-Judge).

# -----------------------------------------------------------------------------
# Option 1: Local Ollama (Default)
# -----------------------------------------------------------------------------
EVAL_LLM_PROVIDER=ollama
EVAL_LLM_MODEL=llama3.1:8b
EVAL_LLM_BASE_URL=http://localhost:11434/v1

# -----------------------------------------------------------------------------
# Option 2: OpenAI
# -----------------------------------------------------------------------------
# EVAL_LLM_PROVIDER=openai
# EVAL_LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Option 3: Google Gemini (via OpenAI-compatible API)
# -----------------------------------------------------------------------------
# EVAL_LLM_PROVIDER=gemini
# EVAL_LLM_MODEL=gemini-2.0-flash
# EVAL_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GOOGLE_API_KEY=...

# -----------------------------------------------------------------------------
# Option 4: Anthropic Claude (via OpenAI-compatible API)
# -----------------------------------------------------------------------------
# EVAL_LLM_PROVIDER=anthropic
# EVAL_LLM_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=...

# =============================================================================
# Rate Limiting (Optional)
# =============================================================================
# Use these settings when running with API-based LLMs that have rate limits.
# Leave unset or set to 0 for no rate limiting (e.g., local Ollama).

# Requests per minute (0 = no limit)
# EVAL_RATE_LIMIT_RPM=60

# Delay between requests in seconds (0 = no delay)
# EVAL_RATE_LIMIT_DELAY=0

# Maximum retries on rate limit errors
# EVAL_RATE_LIMIT_RETRIES=3
